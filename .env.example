# Optional: API base URL (no trailing slash).
# - Local: leave unset. Vite proxies /api to http://localhost:5000 (see vite.config.ts).
# - Production: .env.production sets VITE_API_URL=https://horizon-api-nu.vercel.app
#   so Vercel and local production builds use the deployed backend automatically.
#   Override in Vercel → Settings → Environment Variables if needed.
# VITE_API_URL=
